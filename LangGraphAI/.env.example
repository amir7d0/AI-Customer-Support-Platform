LLM_PROVIDER=nvidia
LLM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_TEMPERATURE=0.2
STREAMING=false

EMBEDDING_PROVIDER=nvidia
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1

VECTOR_STORE_PROVIDER=chroma
VECTOR_STORE_BASE_URL=http://localhost:8000
CHROMA_COLLECTION_NAME=ai_support_documents

RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.7

DATABASE_URL=sqlite:///support.db
DATABASE_DIR=data

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=ai_support_documents
QDRANT_PREFER_GRPC=false

ENABLE_TRACING=false
USE_HUMAN_REVIEW_CALLBACK=false

