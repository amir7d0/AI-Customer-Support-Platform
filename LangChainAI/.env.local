LLM_PROVIDER=openai
LLM_MODEL=Qwen3.5
LLM_API_KEY=dummy
LLM_BASE_URL=http://127.0.0.1:8080/v1/
LLM_TEMPERATURE=0.2
STREAMING=false

EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=http://localhost:8080/v1
EMBEDDING_MODEL=text-embedding-3-small

RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.7

APP_NAME=ai-customer-support
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

LOG_LEVEL=INFO
LOG_FORMAT=json

ESCALATION_CONFIDENCE_THRESHOLD=0.75

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_db
DATA_DIR=data

ENABLE_TRACING=true

MAX_RETRIES=3
REQUEST_TIMEOUT=60

USE_HUMAN_REVIEW_CALLBACK=false

LANGSMITH_PROJECT=ai-customer-support
LANGSMITH_API_KEY=your_langsmith_api_key_here

LANGFUSE_PROJECT=ai-customer-support
LANGFUSE_API_KEY=your_langsmith_api_key_here

CHROMA_COLLECTION_NAME=ai_support_documents
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=ai_support_documents
QDRANT_PREFER_GRPC=false
